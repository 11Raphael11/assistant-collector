generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Business {
  id               String         @id @default(cuid())
  name             String
  type             String
  brandColor       String?
  logoUrl          String?
  supportPhone     String?
  smsCreditBalance Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
  subscriptions    Subscription[]
  users            User[]
  customers        Customer[]
  contracts        Contract[]
  installments     Installment[]
  paymentTokens    PaymentToken[]
  paymentLogs      PaymentLog[]
  messages         Message[]
  messageTemplates MessageTemplate[]
  followUpEvents   FollowUpEvent[]
}

model Customer {
  id               String    @id @default(cuid())
  businessId       String
  name             String
  nameNormalized   String
  phoneEnc         Bytes
  phoneHash        String
  phoneLast4       String
  nationalIdEnc    Bytes?
  nationalIdHash   String?
  note             String?
  createdAt        DateTime  @default(now())
  deletedAt        DateTime?
  business         Business  @relation(fields: [businessId], references: [id])
  contracts        Contract[]
  followUpEvents   FollowUpEvent[]

  @@unique([businessId, phoneHash])
  @@index([businessId])
  @@index([businessId, nameNormalized])
}

enum ContractStatus {
  active
  completed
  canceled
}

model Contract {
  id                String         @id @default(cuid())
  businessId        String
  customerId        String
  totalAmountRial   Int
  downPaymentRial   Int            @default(0)
  installmentCount  Int
  intervalMonths    Int
  startDate         DateTime
  status            ContractStatus @default(active)
  createdAt         DateTime       @default(now())
  deletedAt         DateTime?
  business          Business       @relation(fields: [businessId], references: [id])
  customer          Customer       @relation(fields: [customerId], references: [id])
  installments      Installment[]

  @@index([businessId])
  @@index([businessId, customerId])
}

enum InstallmentStatus {
  pending
  due_soon
  overdue
  promised
  partially_paid
  paid
  in_legal
  canceled
}

model Installment {
  id                 String            @id @default(cuid())
  businessId         String
  contractId         String
  seq                Int
  amountRial         Int
  paidAmountRial     Int               @default(0)
  dueDate            DateTime
  status             InstallmentStatus @default(pending)
  lastReminderStage  Int               @default(0)
  lastReminderAt     DateTime?
  paidAt             DateTime?
  createdAt          DateTime          @default(now())
  deletedAt          DateTime?
  business           Business          @relation(fields: [businessId], references: [id])
  contract           Contract          @relation(fields: [contractId], references: [id])
  paymentTokens      PaymentToken[]
  paymentLogs        PaymentLog[]
  messages           Message[]
  followUpEvents     FollowUpEvent[]

  @@index([dueDate, status])
  @@index([businessId, status])
  @@index([contractId])
}

model PaymentToken {
  id            String       @id @default(cuid())
  businessId    String
  installmentId String
  token         String       @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime     @default(now())
  business      Business     @relation(fields: [businessId], references: [id])
  installment   Installment  @relation(fields: [installmentId], references: [id])

  @@index([businessId, expiresAt])
  @@index([installmentId])
}

enum PaymentLogStatus {
  pending
  paid
  failed
}

model PaymentLog {
  id            String           @id @default(cuid())
  businessId    String
  installmentId String
  transactionId String           @unique
  amountRial    Int
  status        PaymentLogStatus @default(pending)
  authority     String?
  createdAt     DateTime         @default(now())
  business      Business         @relation(fields: [businessId], references: [id])
  installment   Installment      @relation(fields: [installmentId], references: [id])

  @@index([businessId, createdAt])
  @@index([installmentId])
}

enum MessageStage {
  before
  due_day
  after3
  after7
  otp
  payment_confirm
}

enum MessageStatus {
  queued
  sending
  sent
  failed
  dead
}

model Message {
  id              String        @id @default(cuid())
  businessId      String
  installmentId   String?
  to              String
  body            String
  stage           MessageStage
  status          MessageStatus @default(queued)
  idempotencyKey  String        @unique
  attempts        Int           @default(0)
  nextAttemptAt   DateTime?
  providerRef     String?
  createdAt       DateTime      @default(now())
  business        Business      @relation(fields: [businessId], references: [id])
  installment     Installment?  @relation(fields: [installmentId], references: [id])

  @@index([status, nextAttemptAt])
  @@index([businessId])
  @@index([installmentId])
}

enum MessageTone {
  friendly
  formal
  firm
}

model MessageTemplate {
  id         String       @id @default(cuid())
  businessId String
  kind       MessageStage
  tone       MessageTone
  body       String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  business   Business     @relation(fields: [businessId], references: [id])

  @@index([businessId, kind, tone])
}

enum FollowUpEventType {
  promise_to_pay
  extension_request
  note
}

model FollowUpEvent {
  id              String            @id @default(cuid())
  businessId      String
  customerId      String
  installmentId   String?
  type            FollowUpEventType
  promisedDate    DateTime?
  note            String?
  seenByBusiness  Boolean           @default(false)
  createdAt       DateTime          @default(now())
  business        Business          @relation(fields: [businessId], references: [id])
  customer        Customer          @relation(fields: [customerId], references: [id])
  installment     Installment?      @relation(fields: [installmentId], references: [id])

  @@index([businessId, seenByBusiness])
  @@index([businessId, promisedDate])
  @@index([customerId])
  @@index([installmentId])
}

enum UserRole {
  owner
  staff
}

model User {
  id             String   @id @default(cuid())
  businessId     String
  phoneEnc       Bytes
  phoneHash      String   @unique
  phoneLast4     String
  passwordHash   String
  role           UserRole
  sessionVersion Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  business       Business @relation(fields: [businessId], references: [id])

  @@index([businessId])
}

model Plan {
  id               String         @id @default(cuid())
  name             String
  customerCap      Int
  smsQuota         Int
  monthlyPriceRial Int
  features         Json
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  subscriptions    Subscription[]
}

enum SubscriptionStatus {
  active
  expired
  canceled
}

model Subscription {
  id         String             @id @default(cuid())
  businessId String
  planId     String
  status     SubscriptionStatus
  startsAt   DateTime
  endsAt     DateTime?
  graceUntil DateTime?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  business   Business           @relation(fields: [businessId], references: [id])
  plan       Plan               @relation(fields: [planId], references: [id])

  @@index([businessId])
}
